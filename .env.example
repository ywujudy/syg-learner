# 复制为 .env.local 后填入真实值。.env.local 已在 .gitignore 排除，不会推到 git。
# Vercel 上线时把同样的变量填到 Dashboard → Settings → Environment Variables。

# ---- Neon Postgres 连接串 ----
# neon.tech → 创建 project → Connection Details → 复制 pooled connection
DATABASE_URL=postgresql://user:password@ep-xxxx.pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# ---- 腾讯云 SMS（手机号 + 验证码登录）----
# 未填时后端进入 dev 模式，验证码在响应里返回 devCode 便于本地调试
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou

# ---- 微信支付 Native（PC 扫码捐助）----
WX_APPID=
WX_MCHID=
WX_APIV3_KEY=
WX_CERT_SERIAL=
WX_PRIVATE_KEY=
WX_PLATFORM_CERT=
WX_NOTIFY_URL=https://siyange.online/api/donations/notify
